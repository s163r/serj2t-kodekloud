---
- name: Prepare application nodes
  hosts: stapp01.stratos.xfusioncorp.com
  become: true

  tasks:
    - name: Install the latest version of nginx.
      ansible.builtin.package:
        name:
          - nginx
        state: latest

    - name: Enable nginx service
      systemd:
        name: nginx
        enabled: true
      become: true

    - name: Copy private key
      ansible.builtin.copy:
        remote_src: true
        src: /tmp/nautilus.key
        dest: /etc/ssl/private/nautilus.key
        owner: root
        group: root
        mode: '0600'
      become: true

    - name: Copy certificate
      ansible.builtin.copy:
        remote_src: true
        src: /tmp/nautilus.crt
        dest: /etc/ssl/certs/nautilus.crt
        owner: root
        group: root
        mode: '0644'
      become: true
