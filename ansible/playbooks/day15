---
- name: Prepare application nodes
  hosts: stapp01.stratos.xfusioncorp.com
  become: true

  tasks:
    - name: Install the latest version of nginx.
      ansible.builtin.package:
        name:
          - nginx
        state: latest

    - name: Enable nginx service
      systemd:
        name: nginx
        enabled: true
      become: true
